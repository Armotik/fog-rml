@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix ql: <http://semweb.mmlab.be/ns/ql#> .
@prefix ex: <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<#TM1> a rr:TriplesMap ;
  rml:logicalSource [
    rml:source "r3.json" ;
    rml:referenceFormulation ql:JSONPath ;
    rml:iterator "$.issues[*]"
  ] ;
  rr:subjectMap [ rr:template "http://example.org/issue_{id}" ; rr:termType rr:IRI ] ;
  rr:predicateObjectMap [
    rr:predicateMap [ rr:constant ex:issue ] ;
    rr:objectMap [ rr:template "http://example.org/node_{id}" ; rr:termType rr:IRI ] ;
    rr:graphMap [ rr:constant <http://example.org/r3> ]
  ] ;
  .

<#TM_node> a rr:TriplesMap ;
  rml:logicalSource [
    rml:source "r3.json" ;
    rml:referenceFormulation ql:JSONPath ;
    rml:iterator "$.issues[*]"
  ] ;
  rr:subjectMap [ rr:template "http://example.org/node_{id}" ; rr:termType rr:IRI ] ;
  rr:predicateObjectMap [
    rr:predicateMap [ rr:constant ex:title ] ;
    rr:objectMap [ rml:reference "title" ; rr:termType rr:Literal ; rr:datatype xsd:string ] ;
    rr:graphMap [ rr:constant <http://example.org/r3> ]
  ] .
